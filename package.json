{
  "name": "@axisray-lab/gestalt-hud-sdk",
  "version": "0.1.0",
  "description": "HUD modding SDK for Gestalt System — build custom in-game HUDs with real-time attribute data",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js",
      "require": "./dist/protocol/index.cjs"
    },
    "./workshop": {
      "types": "./dist/workshop/index.d.ts",
      "import": "./dist/workshop/index.js",
      "require": "./dist/workshop/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npx vite build && npx vite build --config vite.config.workshop-umd.ts",
    "build:lib": "npx vite build",
    "build:umd": "npx vite build --config vite.config.workshop-umd.ts",
    "dev": "npx vite build --watch",
    "devtools": "npx serve . -l 8080",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gestalt-system",
    "hud",
    "modding",
    "sdk",
    "robomaster",
    "overlay"
  ],
  "author": "Axisray Lab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Axisray-Lab/gestalt-hud-sdk.git"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
